# お問い合わせフォームのメール送信設定（Resend）
# https://resend.com でアカウントを作成し、APIキーを発行してください。

# Resend の API キー（https://resend.com/api-keys で発行）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# お問い合わせの通知先メールアドレス（受信するアドレス）
CONTACT_TO_EMAIL=info@michi-biki.jp

# 送信元メールアドレス（Resend で認証済みのドメインを使用すること）
# 例: "お問い合わせ <noreply@michi-biki.jp>"
CONTACT_FROM_EMAIL=お問い合わせ <noreply@michi-biki.jp>
